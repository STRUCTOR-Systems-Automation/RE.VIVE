# ─────────────────────────────────────────────────────────────────────────────
# Variables de entorno para RE.VIVE
# Copia este archivo como ".env.local" para desarrollo local.
# En producción, añádelas en: Vercel Dashboard → Project → Settings → Environment Variables
# NUNCA subas el archivo .env.local a GitHub.
# ─────────────────────────────────────────────────────────────────────────────

# URL del webhook de n8n (usa la URL de producción, NO la de /webhook-test/)
# Ejemplo: https://tu-n8n.easypanel.host/webhook/RE-VIVE
N8N_WEBHOOK_URL=https://TU_HOST_N8N/webhook/TU_WEBHOOK_ID

# Token secreto que se envía en el header "x-webhook-secret".
# Genera uno con: openssl rand -hex 32
# Configura n8n para que rechace peticiones que no incluyan este valor.
N8N_WEBHOOK_SECRET=cambia_esto_por_un_valor_aleatorio_largo
